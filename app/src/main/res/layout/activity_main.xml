<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="1dp"
    tools:context=".MainActivity">

    <!-- ROW 1: BRANDING & TELEMETRY (20%) -->
    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintHeight_percent="0.2"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            app:cardBackgroundColor="@color/bg_sidebar"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="INTEL.OS" android:textColor="@color/accent_primary" android:textSize="11sp" android:fontFamily="monospace" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PIYUSH PARASHAR" android:textColor="@color/white" android:textSize="10sp" android:fontFamily="monospace" />
                <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
                <TextView android:id="@+id/status_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="SYNC" android:textColor="@color/accent_primary" android:textSize="9sp" android:fontFamily="monospace" android:gravity="center" android:background="#1A1A1A" android:padding="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp">
                <TextView android:id="@+id/cpu_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CPU: --%" android:textColor="@color/white" android:fontFamily="monospace" android:textSize="11sp" />
                <TextView android:id="@+id/mem_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RAM: --GB" android:textColor="@color/white" android:fontFamily="monospace" android:textSize="11sp" />
                <TextView android:id="@+id/disk_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DSK: --%" android:textColor="@color/white" android:fontFamily="monospace" android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INTELLIGENCE FEED (Top Right) -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.5"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="6dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ CYBER.THREAT.INTEL ]" android:textColor="@color/accent_primary" android:textSize="8sp" android:fontFamily="monospace" android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_intel" android:layout_width="match_parent" android:layout_height="match_parent" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ROW 2: KUBERNETES PRIMARY OPS (50%) -->
    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/row1">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/black"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="32dp" android:background="#222222" android:paddingStart="8dp">
                    <TextView android:id="@+id/label_ns" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="[ NS ]" android:textColor="@color/accent_primary" android:textSize="10sp" android:layout_centerVertical="true" android:textStyle="bold" />
                    <Spinner android:id="@+id/spinner_namespace" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_toEndOf="@id/label_ns" android:backgroundTint="@color/accent_primary" />
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_k8s_pods" android:layout_width="match_parent" android:layout_height="match_parent" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.8"
            app:cardBackgroundColor="@color/black"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ MISSION.LOG.STREAM ]" android:textColor="@color/white" android:textSize="8sp" android:padding="4dp" android:background="#111111" android:fontFamily="monospace" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_k8s_logs" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ROW 3: INFRASTRUCTURE & SECURITY RADAR (30%) -->
    <LinearLayout
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintTop_toBottomOf="@id/row2"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ KERNEL.TASKS ]" android:textColor="@color/accent_primary" android:textSize="9sp" android:fontFamily="monospace" android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_processes" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/black" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ DOCKER ]" android:textColor="@color/accent_secondary" android:textSize="9sp" android:fontFamily="monospace" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_docker" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/black" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            app:cardBackgroundColor="@color/black"
            app:cardCornerRadius="0dp"
            android:layout_margin="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ SEC.RADAR ]" android:textColor="#FF5555" android:fontFamily="monospace" android:textSize="8sp" android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_radar" android:layout_width="match_parent" android:layout_height="match_parent" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
