<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="8dp"
    tools:context=".MainActivity">

    <!-- Left Sidebar: Command & Telemetry -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/bg_sidebar"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENGINEERING"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DASHBOARD"
                android:textColor="@color/accent_purple"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SYSTEM"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/cpu_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CPU: --%"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/mem_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RAM: --GB"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/git_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GIT: --"
                android:textColor="@color/accent_purple"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONTROLS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="TESTS"
                app:cornerRadius="8dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/accent_cyan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_git"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="GIT"
                app:cornerRadius="8dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/accent_purple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_build"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="BUILD"
                app:cornerRadius="8dp"
                app:backgroundTint="@color/accent_purple"
                android:textColor="@color/white" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STANDBY"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/bg_glass_card"
                android:letterSpacing="0.2" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Main Grid: TTY, Logs, Processes -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar">

        <!-- Upper: TTY & Logs -->
        <LinearLayout
            android:id="@+id/upper_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/lower_grid"
            app:layout_constraintVertical_weight="1.2">

            <!-- TTY Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="@color/black"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TTY CONSOLE"
                        android:textColor="@color/accent_purple"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_terminal"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logs Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="@color/black"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="EVENT STREAM"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_logs"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Lower: Processes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/lower_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_sidebar"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/upper_grid"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_weight="1.0">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PROCESS OBSERVER (macOS)"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_processes"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@color/black"
                    android:padding="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
